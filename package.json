    "fastify": "5.4.0",
    "googleapis": "169.0.0",
    "http-status-codes": "2.3.0",
    "ioredis": "5.6.1",
    "jsonwebtoken": "9.0.2",
    "lodash": "^4.17.15",
    "luxon": "3.7.2",
    "npm-run-all": "^4.1.5",
    "path-to-regexp": "8.2.0",
    "pg": "8.13.0",
    "pg-hstore": "2.3.4",
    "pino": "9.4.0",
    "psl": "1.15.0",
    "qs": "^6.11.1",
    "sequelize": "6.37.3",
