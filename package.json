    "cross-env": "^7.0.2",
    "eslint": "^6.8.0",
    "eslint-config-standard": "^12.0.0",
    "eslint-plugin-import": "^2.17.3",
    "eslint-plugin-node": "^9.1.0",
    "eslint-plugin-promise": "^4.1.1",
    "eslint-plugin-security": "^1.4.0",
    "eslint-plugin-standard": "^4.0.0",
    "nodemon": "^3.0.1",
    "pre-commit": "1.0.10",
    "supertest": "^4.0.2"
  }
