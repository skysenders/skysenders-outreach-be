{
  "name": "skysenders-outreach-be",
  "version": "1.0.0",
  "description": "Sky Senders Outreach Backend Service",
  "main": "./server/bin/www",
  "engineStrict": true,
  "private": true,
  "license": "",
  "repository": {
    "type": "git"
  },
  "homepage": "",
  "scripts": {
    "start": "npm run dev",
    "build": "npm-run-all clean transpile",
    "server": "node ./dist-server/bin/www",
    "local": "nodemon",
    "dev": "NODE_ENV=DEV npm-run-all build server",
    "prod": "NODE_ENV=PROD npm-run-all build server",
    "windows_dev": "set NODE_ENV=dev&&npm-run-all build server",
    "transpile": "babel ./server --out-dir dist-server",
    "clean": "rimraf dist-server",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . --ext .js,.json .",
    "precommit": "npm run lint"
  },
  "pre-commit": [
    "precommit"
  ],
  "engines": {
    "node": ">= 20.11.1",
    "npm": ">= 9.8.1 < 11.0.0",
    "yarn": "please-use-npm",
    "pnpm": "please-use-npm"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "3.812.0",
    "@aws-sdk/client-s3": "3.688.0",
    "@aws-sdk/client-sqs": "3.675.0",
    "@aws-sdk/s3-request-presigner": "3.688.0",
    "@fastify/cors": "10.0.1",
    "@fastify/jwt": "9.1.0",
    "@fastify/rate-limit": "10.2.2",
    "@fastify/swagger": "9.1.0",
    "@fastify/swagger-ui": "5.0.1",
    "apidoc": "1.2.0",
    "axios": "1.10.0",
    "bcryptjs": "2.4.3",
    "body-parser": "1.20.3",
    "celebrate": "^12.0.1",
    "cors": "^2.8.5",
